{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=fxrates.db"
  },
  "AlphaVantage": {
    "BaseUrl": "https://www.alphavantage.co/query",
    "ApiKey": "YOUR_API_KEY"
  },
  "ExchangeRateLookup": {
    "UseDatabaseCache": true,
    "PersistFetchedRates": true,
    "StaleAfter": "00:15:00"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
